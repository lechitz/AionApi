# Example .env for local seeding - DO NOT COMMIT real secrets
#
# RECOMMENDED: Use `make seed-setup` to auto-generate .env.local with valid values
# This example file is just for reference
#
# Manual generation:
#   make seed-helper
#   ./bin/seed-helper generate-env 100
#
# Or copy this to .env.local and fill manually

# Bcrypt hash used as password for all seeded users
# Generate with: ./bin/seed-helper generate-bcrypt password123
USER_TOKEN_TEST=<bcrypt-hash-placeholder>

# Number of users to generate (used by user_generate.sql)
SEED_USER_COUNT=100

# Plaintext password (for reference only, not used by SQL)
DEV_PASSWORD=password123

# JWT secret key (should match your .env.dev SECRET_KEY)
SECRET_KEY=<your-secret-key>

# Valid JWT token for user 1 (for API testing)
# Generate with: ./bin/seed-helper generate-token 1
JWT_TOKEN=<jwt-token-placeholder>

# Postgres docker info (defaults used by Makefile)
POSTGRES_CONTAINER=postgres-dev
POSTGRES_USER=aion
POSTGRES_DB=aionapi

